# MongoDB connection (use a strong, rotated password in production)
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/portfolio?retryWrites=true&w=majority

# JWT secrets — generate long random strings
JWT_ACCESS_SECRET=change_me_access
JWT_REFRESH_SECRET=change_me_refresh

# Admin seed credentials (used only by npm run seed)
ADMIN_EMAIL=admin@portfolio.local
ADMIN_PASSWORD=ChangeMe!Strong1

# Allowed frontend origin (CORS)
CLIENT_URL=http://localhost:5173

# API port
PORT=5000
